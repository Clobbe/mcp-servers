{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./*/src/index.ts"],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "exclude": [
    "**/node_modules/**",
    "**/build/**",
    "**/__tests__/**",
    "**/*.test.ts"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "readme": "README.md",
  "plugin": [],
  "theme": "default",
  "name": "MCP Servers API Documentation",
  "includeVersion": true,
  "categorizeByGroup": true,
  "categoryOrder": [
    "Tools",
    "Utilities",
    "Types",
    "*"
  ],
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": true
  },
  "githubPages": false,
  "hideGenerator": false
}
